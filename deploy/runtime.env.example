TXZILLA_IMAGE=ghcr.io/your-org/txzilla:latest

APP_ENV=production
APP_PORT=8000
APP_TIMEZONE=America/Chicago

POSTGRES_DB=txzilla
POSTGRES_USER=txzilla
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://txzilla:change-me@db:5432/txzilla

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

COUNTY_DOWNLOAD_DIR=/var/lib/txzilla/county-downloads
ENABLE_BACKGROUND_JOBS=true
COUNTY_SYNC_TASK_ENABLED=true
COUNTY_SYNC_INTERVAL_HOURS=24
ENABLE_DEMO_DATA=false
ENABLE_GEOSPATIAL_FEATURES=true
ENABLE_STARTUP_DB_CHECK=true
AUTO_BOOTSTRAP_ON_STARTUP=false
