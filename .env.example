APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
POSTGRES_DB=txzilla
POSTGRES_USER=txzilla
POSTGRES_PASSWORD=txzilla
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://txzilla:txzilla@localhost:5432/txzilla
REDIS_URL=redis://localhost:6379/0
APP_TIMEZONE=America/Chicago
COUNTY_DOWNLOAD_DIR=/var/lib/txzilla/county-downloads
ENABLE_BACKGROUND_JOBS=true
COUNTY_SYNC_TASK_ENABLED=true
COUNTY_SYNC_INTERVAL_HOURS=24
ENABLE_DEMO_DATA=false
ENABLE_GEOSPATIAL_FEATURES=true
ENABLE_STARTUP_DB_CHECK=true
AUTO_BOOTSTRAP_ON_STARTUP=true
